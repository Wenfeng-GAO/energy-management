                        <color key="backgroundColor" red="0.965" green="0.953" blue="0.918" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                        <constraints>
                            <constraint firstItem="title" firstAttribute="centerX" secondItem="launchView" secondAttribute="centerX" id="titleX"/>
                            <constraint firstItem="title" firstAttribute="centerY" secondItem="launchView" secondAttribute="centerY" constant="-12" id="titleY"/>
